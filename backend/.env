# ===== NVIDIA API =====
# Get your key at https://build.nvidia.com/ (free credits available).
# Replace the value below with your real key before running the backend.
NVIDIA_API_KEY=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

# Optional: override the NVIDIA model. Browse models at https://build.nvidia.com/models
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# ===== Database =====
# Using SQLite. The database name is water_tracker_db.
# The file will be created automatically at backend/data/water_tracker_db.db
DATABASE_URL=sqlite:///./data/water_tracker_db.db

# ===== Backend config =====
HOST=127.0.0.1
PORT=8000

# ===== App behavior =====
# Default daily hydration goal in millilitres
DEFAULT_DAILY_GOAL_ML=2500
